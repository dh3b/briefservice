{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": false,
    "skipLibCheck": true,
    // The reused React/TS code predates verbatimModuleSyntax (which Astro's
    // base config enables); keep it off to match the original strictness.
    "verbatimModuleSyntax": false,
    "types": ["vitest/globals", "astro/client"]
  },
  "include": [".astro/types.d.ts", "src", "**/*.astro"],
  "exclude": ["dist"]
}
