brief-service.com, www.brief-service.com, localhost {
	encode

	# `route` preserves directive order so the API proxy and the bare-domain
	# redirect run before the static file server / SPA fallback.
	route {
		handle /api/* {
			reverse_proxy localhost:3001
		}

		handle /uploads/* {
			reverse_proxy localhost:3001
		}

		# Bare "/" → best matching language home (server-side, no JS),
		# falling back to /en/ for unsupported languages.
		@root_lang {
			path /
			header_regexp rlang Accept-Language ^(pl|en|uk|ru|cs|es|it|hu|ro|lt)
		}
		redir @root_lang /{http.regexp.rlang.1}/ 302

		@root path /
		redir @root /en/ 302

		# Legacy Phase-3 paths → new English routes (permanent).
		@usl_idx path_regexp uslidx ^/([a-z]{2})/uslugi/?$
		redir @usl_idx /{http.regexp.uslidx.1}/services 301
		@usl_slug path_regexp uslslug ^/([a-z]{2})/uslugi/(.+?)/?$
		redir @usl_slug /{http.regexp.uslslug.1}/services/{http.regexp.uslslug.2} 301
		@por_idx path_regexp poridx ^/([a-z]{2})/poradnik/?$
		redir @por_idx /{http.regexp.poridx.1}/guides 301
		@por_slug path_regexp porslug ^/([a-z]{2})/poradnik/(.+?)/?$
		redir @por_slug /{http.regexp.porslug.1}/guides/{http.regexp.porslug.2} 301
		@zmiana path_regexp zmiana ^/([a-z]{2})/zmiana-dmc/?$
		redir @zmiana /{http.regexp.zmiana.1}/services/zmiana-dmc 301

		# Static prerendered pages (Astro, directory format) + 404 fallback.
		handle {
			root * C:/Users/user/Documents/Projects/html/briefservice/dist
			try_files {path} {path}index.html {path}/index.html /404.html
			file_server
		}
	}
}
