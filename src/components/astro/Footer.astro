---
import { translations } from "@/i18n/translations";
import type { Language } from "@/types";
import { getServices, getGuides } from "@/lib/content-source";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang];
const year = new Date().getFullYear();

// Collection links are shown only for languages that actually have content,
// so footers never link to a page that wasn't generated.
const [services, guides] = await Promise.all([getServices(), getGuides()]);
const hasServices = services.some((s) => s.translations[lang]);
const hasGuides = guides.some((g) => g.translations[lang]);
---

<footer class="panel-dark">
  <div class="container-editorial py-16">
    <div class="grid gap-10 md:grid-cols-[1.3fr_1fr_1fr]">
      <div class="max-w-sm">
        <div class="flex items-center gap-2.5">
          <span class="grid h-9 w-9 place-items-center rounded-[11px] bg-terracotta text-paper">
            <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 3.5h7l4 4V20a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4.5a1 1 0 0 1 1-1Z" />
              <path d="M13.5 3.5V8h4.5" />
            </svg>
          </span>
          <span class="font-display text-lg font-extrabold tracking-tight">briefservice</span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-paper/55">{t.footer.description}</p>
      </div>

      <div>
        <p class="eyebrow text-paper/45">{t.ui.contactHeading}</p>
        <ul class="mt-4 space-y-2.5 text-sm text-paper/70">
          <li><a href="tel:+48696513109" class="hover:text-paper transition-colors">+48 696 513 109</a></li>
          <li><a href="mailto:audicarforme@op.pl" class="hover:text-paper transition-colors">audicarforme@op.pl</a></li>
          <li class="text-paper/50">ul. Sosnowa 10/7, 68-100 Żagań</li>
        </ul>
      </div>

      <div>
        <p class="eyebrow text-paper/45">{t.ui.siteHeading}</p>
        <ul class="mt-4 space-y-2.5 text-sm text-paper/70">
          <li><a href={`/${lang}`} class="hover:text-paper transition-colors">{t.nav.home}</a></li>
          {hasServices && <li><a href={`/${lang}/services`} class="hover:text-paper transition-colors">{t.servicesPage.title}</a></li>}
          {hasGuides && <li><a href={`/${lang}/guides`} class="hover:text-paper transition-colors">{t.guidesPage.title}</a></li>}
          <li>
            <a href={`/${lang}/privacy-policy`} class="hover:text-paper transition-colors">{t.footer.cookieNotice.linkText}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-3 border-t border-paper/12 pt-6 text-xs text-paper/45 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} BriefService. {t.footer.rights}</p>
      <p>{t.ui.privateNotice}</p>
    </div>
  </div>
</footer>
