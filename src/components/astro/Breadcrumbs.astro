---
interface Crumb {
  name: string;
  /** Omit on the current (last) page. */
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="breadcrumb" class="container mx-auto px-6">
  <ol class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
    {
      items.map((c, i) => (
        <li class="flex items-center gap-2">
          {c.href ? (
            <a href={c.href} class="hover:text-foreground transition-colors">{c.name}</a>
          ) : (
            <span class="text-foreground font-medium" aria-current="page">{c.name}</span>
          )}
          {i < items.length - 1 && <span class="text-muted-foreground/50">/</span>}
        </li>
      ))
    }
  </ol>
</nav>
