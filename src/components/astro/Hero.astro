---
import { translations } from "@/i18n/translations";
import type { Language } from "@/types";
import featuredImg from "@/assets/featured_service.jpg";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang];
const c = t.hero;
---

<section class="relative overflow-hidden">
  <div class="container-editorial grid items-center gap-12 pt-12 pb-20 md:pt-16 md:pb-28 lg:grid-cols-[1.05fr_0.95fr] lg:gap-8">
    <!-- LEFT: copy (choreographed, staggered entrance) -->
    <div class="max-w-xl">
      <a href="#services" class="pill text-ink/80 transition-colors hover:text-ink" data-reveal>
        <span class="h-2 w-2 rounded-full bg-terracotta"></span>
        <span class="font-medium">{c.badge}</span>
        <svg class="h-3.5 w-3.5 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>

      <h1 class="mt-6 text-[clamp(2.9rem,7.2vw,5.5rem)] leading-[1.02] text-ink" data-reveal style="--reveal-delay: 90ms">
        {c.line1}{" "}
        <span class="serif-em text-terracotta">{c.em}</span>{c.line2}
      </h1>

      <p class="mt-5 font-serif text-[clamp(1.15rem,2.2vw,1.6rem)] italic text-terracotta" data-reveal style="--reveal-delay: 180ms">
        {c.tagline}
      </p>

      <p class="mt-5 max-w-md text-[15px] leading-relaxed text-muted-foreground" data-reveal style="--reveal-delay: 250ms">
        {t.hero.titleAccent}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3" data-reveal style="--reveal-delay: 330ms">
        <a href="#services" class="btn-primary">
          {t.hero.cta}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
        <a href="#contact" class="btn-secondary">{t.hero.chatCta}</a>
      </div>
    </div>

    <!-- RIGHT: floating cards -->
    <div class="relative h-[480px] sm:h-[560px] lg:h-[600px]" aria-hidden="true">
      <!-- Document card (main) - a realistic German Fahrzeugbrief (Teil II) -->
      <article
        data-parallax="0.02"
        class="hero-card card-surface shadow-float absolute inset-x-0 top-0 z-20 mx-auto w-[306px] p-6 sm:w-[344px] lg:right-auto lg:mx-0"
        style="--card-delay: 200ms; transform: translateY(var(--py, 0px)) rotate(-4deg)"
      >
        <div>
          <span class="eyebrow block">Zulassungsbescheinigung</span>
          <span class="font-display text-sm font-extrabold text-ink">Teil II · Fahrzeugbrief</span>
        </div>
        <div class="mt-4 flex items-end justify-between gap-3 rounded-xl bg-secondary/60 px-3.5 py-2.5">
          <div>
            <span class="eyebrow text-[9px]">Brief-Nr.</span>
            <div class="font-mono text-xl font-medium tracking-tight text-ink">ABF 04 9931</div>
          </div>
          <span class="mb-0.5 grid h-7 w-7 place-items-center rounded-full bg-terracotta/12 text-[10px] font-bold tracking-wide text-terracotta">DE</span>
        </div>
        <dl class="mt-4 space-y-2.5 text-sm">
          <div class="flex items-baseline justify-between gap-3 border-b border-border/70 pb-2">
            <dt class="text-muted-foreground"><span class="font-mono text-[11px] text-terracotta/70">D.1</span> Marke</dt>
            <dd class="font-medium text-ink">Mercedes-Benz</dd>
          </div>
          <div class="flex items-baseline justify-between gap-3 border-b border-border/70 pb-2">
            <dt class="text-muted-foreground"><span class="font-mono text-[11px] text-terracotta/70">D.3</span> Typ</dt>
            <dd class="font-medium text-ink">Sprinter 316 CDI</dd>
          </div>
          <div class="flex items-baseline justify-between gap-3 border-b border-border/70 pb-2">
            <dt class="text-muted-foreground"><span class="font-mono text-[11px] text-terracotta/70">J</span> Fahrzeugklasse</dt>
            <dd class="font-semibold text-ink">N1 <span class="font-normal text-muted-foreground">· Lkw</span></dd>
          </div>
          <div class="flex items-baseline justify-between gap-3 border-b border-border/70 pb-2">
            <dt class="text-muted-foreground"><span class="font-mono text-[11px] text-terracotta/70">E</span> FIN</dt>
            <dd class="font-mono text-ink">WDB907…</dd>
          </div>
          <div class="flex items-baseline justify-between gap-3">
            <dt class="text-muted-foreground"><span class="font-mono text-[11px] text-terracotta/70">F.1</span> zul. Gesamtmasse</dt>
            <dd class="font-semibold text-terracotta">3 500 kg</dd>
          </div>
        </dl>
        <div class="mt-4 flex items-center gap-2 border-t border-border pt-3.5">
          <span class="grid h-7 w-7 place-items-center rounded-full bg-emerald-500/15 text-emerald-600">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
          </span>
          <span class="text-xs text-muted-foreground">Neuer Brief ausgestellt · gültig in der EU</span>
        </div>
      </article>

      <!-- Service result card -->
      <article
        data-parallax="0.05"
        class="hero-card card-surface shadow-float absolute bottom-0 right-0 z-10 w-[260px] p-5 sm:w-[280px]"
        style="--card-delay: 400ms; transform: translateY(var(--py, 0px)) rotate(3deg)"
      >
        <div class="flex items-center gap-2">
          <span class="grid h-7 w-7 place-items-center rounded-full bg-emerald-500/15 text-emerald-600">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
          </span>
          <span class="eyebrow">zul. Gesamtmasse</span>
        </div>
        <div class="mt-3 font-display text-xl font-extrabold text-ink">5 000 → <span class="text-terracotta">3 500 kg</span></div>
        <p class="mt-1 text-xs text-muted-foreground">{c.resultCardText}</p>
      </article>

      <!-- Photo chip -->
      <div
        data-parallax="0.035"
        class="hero-card shadow-float absolute right-0 top-1 z-30 h-24 w-36 overflow-hidden rounded-2xl border border-border sm:right-6 sm:h-28 sm:w-40 lg:right-auto lg:left-[310px]"
        style="--card-delay: 320ms; transform: translateY(var(--py, 0px)) rotate(-2deg)"
      >
        <img src={featuredImg.src} alt="" class="h-full w-full object-cover" />
      </div>

      <!-- Approval seal accent (stamp on the document) -->
      <div
        data-parallax="0.06"
        class="hero-card absolute bottom-6 left-0 z-30 grid h-[76px] w-[76px] place-items-center rounded-full bg-ink text-paper shadow-float sm:left-4"
        style="--card-delay: 520ms; transform: translateY(var(--py, 0px)) rotate(-10deg)"
      >
        <div class="grid h-[60px] w-[60px] place-items-center gap-0.5 rounded-full border border-paper/25 text-center">
          <svg class="h-4 w-4 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
          <span class="font-mono text-[8px] uppercase leading-none tracking-[0.12em]">TÜV<br />§21</span>
        </div>
      </div>
    </div>
  </div>
</section>
