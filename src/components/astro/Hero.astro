---
import { translations } from "@/i18n/translations";
import type { Language } from "@/types";
import featuredImg from "@/assets/featured_service.jpg";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang];

// Short redesign microcopy (headline / badge / tagline). Body + buttons reuse
// the existing translated strings. Falls back to English for any missing locale.
type HeroCopy = { badge: string; line1: string; em: string; line2: string; tagline: string };
const COPY: Partial<Record<Language, HeroCopy>> = {
  pl: { badge: "Prywatny serwis — nie urząd", line1: "Niemieckie formalności", em: "pojazdowe", line2: ", ogarnięte.", tagline: "Załatwiamy to za Ciebie — w Niemczech." },
  en: { badge: "Private service — not an authority", line1: "German vehicle", em: "paperwork", line2: ", handled.", tagline: "We take care of it for you — in Germany." },
  ru: { badge: "Частный сервис — не госорган", line1: "Автомобильные формальности", em: "в Германии", line2: " — под ключ.", tagline: "Мы всё оформим за вас." },
  uk: { badge: "Приватний сервіс — не держустанова", line1: "Автомобільні формальності", em: "у Німеччині", line2: " — під ключ.", tagline: "Ми все оформимо за вас." },
  cs: { badge: "Soukromá služba — ne úřad", line1: "Německé vozidlové", em: "formality", line2: ", vyřízené.", tagline: "Vyřídíme to za vás — v Německu." },
  es: { badge: "Servicio privado — no una autoridad", line1: "Trámites de vehículos", em: "alemanes", line2: ", resueltos.", tagline: "Nos encargamos por ti — en Alemania." },
  it: { badge: "Servizio privato — non un ente", line1: "Pratiche auto", em: "tedesche", line2: ", risolte.", tagline: "Ce ne occupiamo noi — in Germania." },
  hu: { badge: "Magánszolgáltatás — nem hatóság", line1: "Német járműügyintézés", em: "egyszerűen", line2: ".", tagline: "Elintézzük helyetted — Németországban." },
  ro: { badge: "Serviciu privat — nu o autoritate", line1: "Formalități auto", em: "germane", line2: ", rezolvate.", tagline: "Ne ocupăm noi — în Germania." },
  lt: { badge: "Privati paslauga — ne įstaiga", line1: "Vokiški transporto", em: "formalumai", line2: ", sutvarkyti.", tagline: "Pasirūpinsime už jus — Vokietijoje." },
};
const c = COPY[lang] ?? COPY.en!;
---

<section class="relative overflow-hidden">
  <div class="container-editorial grid items-center gap-12 pt-12 pb-20 md:pt-16 md:pb-28 lg:grid-cols-[1.05fr_0.95fr] lg:gap-8">
    <!-- LEFT: copy -->
    <div class="max-w-xl" data-reveal>
      <a href="#services" class="pill text-ink/80 hover:text-ink transition-colors">
        <span class="h-2 w-2 rounded-full bg-terracotta"></span>
        <span class="font-medium">{c.badge}</span>
        <svg class="h-3.5 w-3.5 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>

      <h1 class="mt-6 text-[clamp(2.9rem,7.2vw,5.5rem)] leading-[1.02] text-ink">
        {c.line1}{" "}
        <span class="serif-em text-terracotta">{c.em}</span>{c.line2}
      </h1>

      <p class="mt-5 font-serif text-[clamp(1.15rem,2.2vw,1.6rem)] italic text-terracotta">
        {c.tagline}
      </p>

      <p class="mt-5 max-w-md text-[15px] leading-relaxed text-muted-foreground">
        {t.hero.titleAccent}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="#services" class="btn-primary">
          {t.hero.cta}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
        <a href="#contact" class="btn-secondary">{t.hero.chatCta}</a>
      </div>
    </div>

    <!-- RIGHT: floating cards -->
    <div class="relative h-[420px] sm:h-[480px] lg:h-[560px]" aria-hidden="true">
      <!-- Document card (main) -->
      <article
        data-parallax="0.03"
        class="card-surface shadow-float absolute left-1/2 top-4 w-[300px] -translate-x-1/2 -rotate-[4deg] p-6 sm:w-[340px] lg:left-2 lg:translate-x-0"
      >
        <div class="flex items-center justify-between">
          <span class="eyebrow">Zulassungsbescheinigung · Teil II</span>
          <span class="h-2.5 w-2.5 rounded-full bg-terracotta"></span>
        </div>
        <div class="mt-4 font-mono text-2xl font-medium tracking-tight text-ink">ABF 04 9931</div>
        <dl class="mt-5 space-y-3 text-sm">
          <div class="flex justify-between border-b border-border pb-2"><dt class="text-muted-foreground">Marke</dt><dd class="font-medium text-ink">Mercedes-Benz</dd></div>
          <div class="flex justify-between border-b border-border pb-2"><dt class="text-muted-foreground">FIN</dt><dd class="font-mono text-ink">WDB…0042</dd></div>
          <div class="flex justify-between"><dt class="text-muted-foreground">zul. Gesamtmasse</dt><dd class="font-semibold text-terracotta">3 500 kg</dd></div>
        </dl>
        <div class="mt-5 flex items-center gap-2 border-t border-border pt-4">
          <span class="grid h-8 w-8 place-items-center rounded-full bg-terracotta/12 text-[10px] font-bold text-terracotta">DE</span>
          <span class="text-xs text-muted-foreground">Neuer Brief ausgestellt</span>
        </div>
      </article>

      <!-- Service result card -->
      <article
        data-parallax="0.07"
        class="card-surface shadow-float absolute bottom-6 right-0 w-[260px] rotate-[3deg] p-5 sm:w-[280px]"
      >
        <div class="flex items-center gap-2">
          <span class="grid h-7 w-7 place-items-center rounded-full bg-emerald-500/15 text-emerald-600">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
          </span>
          <span class="eyebrow">Zmiana DMC</span>
        </div>
        <div class="mt-3 font-display text-xl font-extrabold text-ink">5 000 → <span class="text-terracotta">3 500 kg</span></div>
        <p class="mt-1 text-xs text-muted-foreground">Nowe Briefy + tabliczka znamionowa. Ważne w całej UE.</p>
      </article>

      <!-- Photo chip -->
      <div
        data-parallax="0.05"
        class="shadow-float absolute right-6 top-0 h-28 w-40 -rotate-2 overflow-hidden rounded-2xl border border-border sm:right-12"
      >
        <img src={featuredImg.src} alt="" class="h-full w-full object-cover" />
      </div>

      <!-- Tiny seal accent -->
      <div
        data-parallax="0.1"
        class="absolute bottom-24 left-2 grid h-16 w-16 rotate-[8deg] place-items-center rounded-full bg-ink text-paper shadow-float sm:left-6"
      >
        <span class="font-mono text-[10px] leading-tight text-center">TÜV<br />OK</span>
      </div>
    </div>
  </div>
</section>
