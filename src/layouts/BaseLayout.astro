---
import "@/index.css";
import {
  canonicalUrl,
  hreflangAlternates,
  organizationSchema,
  type Language,
} from "@/seo/site";

interface Props {
  lang: Language;
  /** Document <title>. */
  title: string;
  /** Meta description. */
  description: string;
  /** Path after the language segment ("" for the language home page). */
  path: string;
  /** When true, emit noindex and skip hreflang alternates. */
  noindex?: boolean;
  /** Optional JSON-LD object(s) to embed in addition to Organization. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { lang, title, description, path, noindex = false, jsonLd } = Astro.props;

const canonical = canonicalUrl(lang, path);
const alternates = noindex ? [] : hreflangAlternates(path);
const pageSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const schemas = [organizationSchema(), ...pageSchemas];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="Marek Jurecki" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BriefService" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang} />

    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={a.href} />
      ))
    }

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-17997426374"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-17997426374');
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-PWVLKZFC');</script>
    <!-- End Google Tag Manager -->

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="BriefService" />
    <link rel="manifest" href="/site.webmanifest" />

    {schemas.map((schema) => <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />)}
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-PWVLKZFC"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->

    <slot />
  </body>
</html>
