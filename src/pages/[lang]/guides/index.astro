---
import { translations } from "@/i18n/translations";
import { type Language } from "@/types";
import { canonicalUrl, breadcrumbSchema } from "@/seo/site";
import { getServices, getGuides, listingLangs } from "@/lib/content-source";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/astro/Navbar.astro";
import Footer from "@/components/astro/Footer.astro";
import Breadcrumbs from "@/components/astro/Breadcrumbs.astro";
import ChatIsland from "@/islands/ChatIsland";

export async function getStaticPaths() {
  const guides = await getGuides();
  return listingLangs(guides).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Language;
const t = translations[lang];

const allGuides = await getGuides();
const allServices = await getServices();
const guides = allGuides
  .filter((g) => g.translations[lang])
  .map((g) => ({ slug: g.slug, ...g.translations[lang]! }));
const hasServices = allServices.some((s) => s.translations[lang]);

const c = t.guidesPage;
const path = "guides";
const guideListingLangs = listingLangs(allGuides);

const navLinks = [
  { label: t.nav.home, href: `/${lang}` },
  ...(hasServices ? [{ label: t.servicesPage.title, href: `/${lang}/services` }] : []),
  { label: c.title, href: `/${lang}/guides` },
];

const jsonLd = [
  breadcrumbSchema([
    { name: t.nav.home, url: canonicalUrl(lang, "") },
    { name: c.title, url: canonicalUrl(lang, path) },
  ]),
];
---

<BaseLayout
  lang={lang}
  title={c.metaTitle}
  description={c.metaDescription}
  path={path}
  hreflangLangs={guideListingLangs}
  jsonLd={jsonLd}
>
  <Navbar lang={lang} navLinks={navLinks} langSuffix="/guides" availableLangs={guideListingLangs} />
  <main class="pt-8 pb-16">
    <Breadcrumbs items={[{ name: t.nav.home, href: `/${lang}` }, { name: c.title }]} />
    <section class="container-editorial pt-6">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow">{c.eyebrow}</p>
        <h1 class="mt-3 text-[clamp(2.2rem,4.8vw,3.5rem)] text-ink">{c.title}</h1>
        <p class="mt-4 text-[15px] leading-relaxed text-muted-foreground">{c.intro}</p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2" data-reveal>
        {
          guides.map((g) => (
            <a
              href={`/${lang}/guides/${g.slug}`}
              class="card-surface group flex flex-col rounded-2xl border border-border bg-paper p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-float"
            >
              <h2 class="font-display text-lg font-extrabold leading-snug text-ink group-hover:text-terracotta transition-colors">
                {g.title}
              </h2>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{g.excerpt}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>
  <Footer lang={lang} />
  <ChatIsland lang={lang} client:idle />
</BaseLayout>
