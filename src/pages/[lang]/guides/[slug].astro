---
import { translations } from "@/i18n/translations";
import { type Language } from "@/types";
import { canonicalUrl, faqSchema, breadcrumbSchema } from "@/seo/site";
import {
  getServices,
  getGuides,
  availableLangs,
  resolveTranslation,
  makeGuideLinkResolver,
} from "@/lib/content-source";
import { renderMarkdown } from "@/lib/markdown";
import type { Faq } from "@/content/types";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/astro/Navbar.astro";
import Footer from "@/components/astro/Footer.astro";
import Breadcrumbs from "@/components/astro/Breadcrumbs.astro";
import ChatIsland from "@/islands/ChatIsland";

interface Cta {
  href: string;
  label: string;
  text: string;
}

export async function getStaticPaths() {
  const [services, guides] = await Promise.all([getServices(), getGuides()]);
  const paths = [];
  for (const guide of guides) {
    for (const lang of availableLangs(guide)) {
      const tr = guide.translations[lang]!;
      const bodyHtml = renderMarkdown(tr.markdown, {
        resolveGuide: makeGuideLinkResolver(guides, lang),
      });
      let cta: Cta | null = null;
      if (tr.cta) {
        const svc = services.find((s) => s.slug === tr.cta!.serviceSlug);
        const svcT = svc ? resolveTranslation(svc, lang) : null;
        const href = svc
          ? `/${svcT?.resolvedLang ?? lang}/services/${svc.slug}`
          : `/${lang}/services`;
        cta = { href, label: tr.cta.label, text: tr.cta.text };
      }
      paths.push({
        params: { lang, slug: guide.slug },
        props: {
          slug: guide.slug,
          h1: tr.h1 ?? tr.title,
          seoTitle: tr.seoTitle ?? tr.title,
          seoDescription: tr.seoDescription || tr.excerpt,
          excerpt: tr.excerpt,
          faq: tr.faq ?? [],
          bodyHtml,
          cta,
          langs: availableLangs(guide),
        },
      });
    }
  }
  return paths;
}

const lang = Astro.params.lang as Language;
const { slug, h1, seoTitle, seoDescription, excerpt, faq, bodyHtml, cta, langs } = Astro.props as {
  slug: string;
  h1: string;
  seoTitle: string;
  seoDescription: string;
  excerpt: string;
  faq: Faq[];
  bodyHtml: string;
  cta: Cta | null;
  langs: Language[];
};

const t = translations[lang];
const guideLabel = t.guidesPage.title;
const path = `guides/${slug}`;
const url = canonicalUrl(lang, path);

const services = await getServices();
const hasServices = services.some((s) => s.translations[lang]);
const navLinks = [
  { label: t.nav.home, href: `/${lang}` },
  ...(hasServices ? [{ label: t.servicesPage.title, href: `/${lang}/services` }] : []),
  { label: guideLabel, href: `/${lang}/guides` },
];

const jsonLd = [
  ...(faq.length ? [faqSchema(faq)] : []),
  breadcrumbSchema([
    { name: t.nav.home, url: canonicalUrl(lang, "") },
    { name: guideLabel, url: canonicalUrl(lang, "guides") },
    { name: h1, url },
  ]),
];
const faqHeading = t.ui.faqHeading;
---

<BaseLayout
  lang={lang}
  title={seoTitle}
  description={seoDescription}
  path={path}
  hreflangLangs={langs}
  jsonLd={jsonLd}
>
  <Navbar lang={lang} navLinks={navLinks} langSuffix={`/guides/${slug}`} availableLangs={langs} />
  <main class="pt-8 pb-4">
    <Breadcrumbs
      items={[
        { name: t.nav.home, href: `/${lang}` },
        { name: guideLabel, href: `/${lang}/guides` },
        { name: h1 },
      ]}
    />
    <article class="container-editorial max-w-3xl py-8">
      <h1 class="text-[clamp(2rem,4.5vw,3.25rem)] text-ink">{h1}</h1>
      {excerpt && <p class="mt-5 text-lg leading-relaxed text-muted-foreground">{excerpt}</p>}

      <div class="prose-editorial mt-10" set:html={bodyHtml} />

      {
        faq.length > 0 && (
          <section class="mt-16">
            <h2 class="font-display text-2xl font-extrabold text-ink">{faqHeading}</h2>
            <div class="mt-6 divide-y divide-border border-t border-border">
              {faq.map((f) => (
                <div class="py-5">
                  <h3 class="font-semibold text-ink">{f.q}</h3>
                  <p class="mt-1.5 leading-relaxed text-ink/75">{f.a}</p>
                </div>
              ))}
            </div>
          </section>
        )
      }

      {
        cta && (
          <aside
            class="mt-14 flex flex-col justify-between gap-4 rounded-2xl border border-terracotta/30 p-7 sm:flex-row sm:items-center"
            style="background-color: hsl(var(--clay-tint) / 0.55)"
          >
            <p class="text-sm leading-relaxed text-ink/80">{cta.text}</p>
            <a href={cta.href} class="btn-primary whitespace-nowrap">
              {cta.label}
            </a>
          </aside>
        )
      }
    </article>
  </main>
  <Footer lang={lang} />
  <ChatIsland lang={lang} client:idle />
</BaseLayout>
