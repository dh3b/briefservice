---
import { translations } from "@/i18n/translations";
import { type Language } from "@/types";
import { canonicalUrl, breadcrumbSchema } from "@/seo/site";
import { getServices, getGuides, listingLangs } from "@/lib/content-source";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/astro/Navbar.astro";
import Footer from "@/components/astro/Footer.astro";
import Breadcrumbs from "@/components/astro/Breadcrumbs.astro";
import ContactIsland from "@/islands/ContactIsland";
import ChatIsland from "@/islands/ChatIsland";

export async function getStaticPaths() {
  const services = await getServices();
  return listingLangs(services).map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Language;
const t = translations[lang];

const allServices = await getServices();
const allGuides = await getGuides();
// Only show services that have a translation in this language (no mixed-locale).
const services = allServices
  .filter((s) => s.translations[lang])
  .map((s) => ({ slug: s.slug, featured: s.featured, ...s.translations[lang]! }));
const hasGuides = allGuides.some((g) => g.translations[lang]);

const c = t.servicesPage;
const path = "services";
const serviceListingLangs = listingLangs(allServices);

const navLinks = [
  { label: t.nav.home, href: `/${lang}` },
  { label: c.title, href: `/${lang}/services` },
  ...(hasGuides ? [{ label: t.guidesPage.title, href: `/${lang}/guides` }] : []),
];

const jsonLd = [
  breadcrumbSchema([
    { name: t.nav.home, url: canonicalUrl(lang, "") },
    { name: c.title, url: canonicalUrl(lang, path) },
  ]),
];
---

<BaseLayout
  lang={lang}
  title={c.metaTitle}
  description={c.metaDescription}
  path={path}
  hreflangLangs={serviceListingLangs}
  jsonLd={jsonLd}
>
  <Navbar lang={lang} navLinks={navLinks} langSuffix="/services" availableLangs={serviceListingLangs} />
  <main class="pt-8 pb-4">
    <Breadcrumbs items={[{ name: t.nav.home, href: `/${lang}` }, { name: c.title }]} />
    <section class="container-editorial pt-6 pb-12 md:pb-16">
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow">{c.eyebrow}</p>
        <h1 class="mt-3 text-[clamp(2.2rem,4.8vw,3.5rem)] text-ink">{c.title}</h1>
        <p class="mt-4 text-[15px] leading-relaxed text-muted-foreground">{c.intro}</p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal>
        {
          services.map((s) =>
            s.featured ? (
              <a
                href={`/${lang}/services/${s.slug}`}
                class="panel-dark group relative flex flex-col justify-between overflow-hidden rounded-2xl p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-float sm:col-span-2 lg:col-span-1"
              >
                <div class="pointer-events-none absolute -right-16 -top-16 h-44 w-44 rounded-full bg-terracotta/25 blur-3xl" />
                <div class="relative">
                  <span class="eyebrow text-terracotta">{t.services.featured}</span>
                  <h2 class="mt-4 font-display text-2xl font-extrabold leading-tight text-paper">{s.title}</h2>
                  <p class="mt-3 text-sm leading-relaxed text-paper/60">{s.excerpt}</p>
                </div>
                <span class="relative mt-7 inline-flex items-center gap-2 text-sm font-semibold text-terracotta">
                  {t.ui.learnMore}
                  <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
                </span>
              </a>
            ) : (
              <a
                href={`/${lang}/services/${s.slug}`}
                class="card-surface group flex flex-col rounded-2xl border border-border bg-paper p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-float"
              >
                <h2 class="font-display text-xl font-extrabold leading-snug text-ink group-hover:text-terracotta transition-colors">{s.title}</h2>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{s.excerpt}</p>
                <span class="mt-auto inline-flex items-center gap-1 pt-6 text-sm font-semibold text-ink">
                  {t.services.details}
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10" /><path d="M7 17 17 7" /></svg>
                </span>
              </a>
            ),
          )
        }
      </div>
    </section>

    <ContactIsland lang={lang} client:visible />
  </main>
  <Footer lang={lang} />
  <ChatIsland lang={lang} client:idle />
</BaseLayout>
