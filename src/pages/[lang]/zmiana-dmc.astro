---
import { translations } from "@/i18n/translations";
import { SUPPORTED_LANGUAGES, type Language } from "@/types";
import { canonicalUrl, serviceSchema, breadcrumbSchema } from "@/seo/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/astro/Navbar.astro";
import Footer from "@/components/astro/Footer.astro";
import ContactIsland from "@/islands/ContactIsland";
import ChatIsland from "@/islands/ChatIsland";

export function getStaticPaths() {
  return SUPPORTED_LANGUAGES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Language;
const t = translations[lang];
const d = t.zmianaDmc;

const navLinks = [{ label: d.nav.home, href: `/${lang}` }];

const url = canonicalUrl(lang, "zmiana-dmc");
const jsonLd = [
  serviceSchema({ name: d.seo.title, description: d.seo.description, url }),
  breadcrumbSchema([
    { name: t.nav.home, url: canonicalUrl(lang, "") },
    { name: d.seo.title, url },
  ]),
];

const steps = [
  { n: "01", h: d.howItWorks.step1, p: d.howItWorks.step1Desc },
  { n: "02", h: d.howItWorks.step2, p: d.howItWorks.step2Desc },
  { n: "03", h: d.howItWorks.step3, p: d.howItWorks.step3Desc },
  { n: "04", h: d.howItWorks.step4, p: d.howItWorks.step4Desc },
];

const s2500 = d.service2500;
const s3500 = d.service3500;
---

<BaseLayout lang={lang} title={d.seo.title} description={d.seo.description} path="zmiana-dmc" jsonLd={jsonLd}>
  <Navbar lang={lang} langSuffix="/zmiana-dmc" navLinks={navLinks} />

  <main>
    <!-- INTRO -->
    <section class="container-editorial pt-16 pb-12 md:pt-24 md:pb-16">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow">{d.service2500.tag}</p>
        <h1 class="mt-4 text-[clamp(2.4rem,5.2vw,4.25rem)] text-ink">{d.intro.title}</h1>
        <p class="mt-6 max-w-2xl text-[15px] leading-relaxed text-muted-foreground">{d.intro.subtitle}</p>
      </div>
    </section>

    <!-- SERVICE CARDS -->
    <section id="services" class="container-editorial pb-4">
      <div class="grid gap-7 md:grid-cols-2">
        <!-- DMC 2500 -->
        <article data-reveal class="flex flex-col overflow-hidden rounded-2xl border border-border bg-paper shadow-float">
          <div class="bg-ink p-8 pb-7">
            <span class="inline-block rounded-full bg-terracotta/15 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-terracotta">{s2500.tag}</span>
            <h2 class="mt-3.5 font-display text-2xl font-extrabold leading-tight text-paper">{s2500.title}</h2>
            <p class="mt-1.5 text-sm text-paper/60">{s2500.subtitle}</p>
          </div>
          <div class="flex flex-1 flex-col gap-6 px-8 py-7">
            <div class="space-y-3 text-[0.95rem] leading-relaxed text-ink/80">{s2500.lead.map((p) => <p>{p}</p>)}</div>
            <div>
              <h3 class="eyebrow mb-3">{s2500.scopeTitle}</h3>
              <div class="space-y-3 text-[0.92rem] leading-relaxed text-muted-foreground">{s2500.scopeText.map((p) => <p>{p}</p>)}</div>
              <p class="mt-4 border-l-2 border-terracotta pl-3.5 text-[0.92rem] font-semibold text-ink">{s2500.scopeNote}</p>
            </div>
            <div>
              <h3 class="eyebrow mb-3">{s2500.getTitle}</h3>
              <ul class="space-y-2.5">
                {s2500.getList.map((item) => (
                  <li class="flex items-start gap-3 text-[0.92rem] text-ink/90">
                    <span class="mt-[0.55rem] h-1.5 w-1.5 shrink-0 rounded-[2px] bg-terracotta" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="mt-auto pt-1">
              <h3 class="eyebrow mb-2">{s2500.verifyTitle}</h3>
              <p class="text-[0.92rem] leading-relaxed text-ink/80">{s2500.verifyText}</p>
              <p class="mt-3 border-t border-border pt-3 text-xs leading-relaxed text-muted-foreground">{s2500.verifyPhotos}</p>
            </div>
          </div>
        </article>

        <!-- DMC 3500 -->
        <article data-reveal class="flex flex-col overflow-hidden rounded-2xl border border-border bg-paper shadow-float">
          <div class="bg-ink p-8 pb-7">
            <span class="inline-block rounded-full bg-terracotta/15 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-terracotta">{s3500.tag}</span>
            <h2 class="mt-3.5 font-display text-2xl font-extrabold leading-tight text-paper">{s3500.title}</h2>
            <p class="mt-1.5 text-sm text-paper/60">{s3500.subtitle}</p>
          </div>
          <div class="flex flex-1 flex-col gap-6 px-8 py-7">
            <div class="space-y-3 text-[0.95rem] leading-relaxed text-ink/80">{s3500.lead.map((p) => <p>{p}</p>)}</div>
            <div>
              <h3 class="eyebrow mb-3">{s3500.scopeTitle}</h3>
              <div class="space-y-3 text-[0.92rem] leading-relaxed text-muted-foreground">{s3500.scopeText.map((p) => <p>{p}</p>)}</div>
              <p class="mt-4 border-l-2 border-terracotta pl-3.5 text-[0.92rem] font-semibold text-ink">{s3500.scopeNote}</p>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how" class="section bg-cream mt-4">
      <div class="container-editorial">
        <h2 class="text-center text-[clamp(2rem,4vw,3rem)] text-ink" data-reveal>{d.howItWorks.title}</h2>
        <div class="mt-12 grid gap-x-8 gap-y-10 sm:grid-cols-2 md:grid-cols-4">
          {
            steps.map((s) => (
              <div data-reveal>
                <div class="font-mono text-3xl font-medium text-terracotta">{s.n}</div>
                <h4 class="mt-3 font-display text-lg font-extrabold text-ink">{s.h}</h4>
                <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{s.p}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- NOTE -->
    <section class="container-editorial py-14">
      <div class="flex items-start gap-4 rounded-2xl border border-terracotta/30 p-7" data-reveal style="background-color: hsl(18 48% 92% / 0.55)">
        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-terracotta/15 text-terracotta">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line>
          </svg>
        </span>
        <p class="text-sm leading-relaxed text-ink/80">{d.note.description}</p>
      </div>
    </section>

    <ContactIsland lang={lang} client:visible />
  </main>

  <Footer lang={lang} />
  <ChatIsland lang={lang} client:idle />
</BaseLayout>
