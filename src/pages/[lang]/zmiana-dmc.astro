---
import { translations } from "@/i18n/translations";
import { SUPPORTED_LANGUAGES, type Language } from "@/types";
import { canonicalUrl, serviceSchema, breadcrumbSchema } from "@/seo/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/astro/Navbar.astro";
import Footer from "@/components/astro/Footer.astro";
import ContactIsland from "@/islands/ContactIsland";
import ChatIsland from "@/islands/ChatIsland";

export function getStaticPaths() {
  return SUPPORTED_LANGUAGES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Language;
const t = translations[lang];
const d = t.zmianaDmc;

const navLinks = [{ label: d.nav.home, href: `/${lang}` }];

const url = canonicalUrl(lang, "zmiana-dmc");
const jsonLd = [
  serviceSchema({ name: d.seo.title, description: d.seo.description, url }),
  breadcrumbSchema([
    { name: t.nav.home, url: canonicalUrl(lang, "") },
    { name: d.seo.title, url },
  ]),
];
---

<BaseLayout lang={lang} title={d.seo.title} description={d.seo.description} path="zmiana-dmc" jsonLd={jsonLd}>
  <div class="min-h-screen bg-background">
    <Navbar lang={lang} langSuffix="/zmiana-dmc" navLinks={navLinks} />

    <main class="pt-16">
      <!-- INTRO -->
      <section class="py-20 px-6">
        <div class="container mx-auto max-w-4xl text-center">
          <h1 class="font-display text-4xl md:text-5xl font-bold text-foreground mb-6">
            {d.intro.title}
          </h1>
          <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
            {d.intro.subtitle}
          </p>
        </div>
      </section>

      <!-- SERVICES -->
      <section id="services" class="px-6 pb-16">
        <div class="container mx-auto max-w-5xl grid md:grid-cols-2 gap-8">
          <!-- CARD 1: DMC 2500 -->
          <article class="bg-card rounded-xl border border-border overflow-hidden flex flex-col">
            <div class="bg-[#1e3a5f] p-8 pb-7">
              <span class="inline-block px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.12em] rounded bg-[#d4a94c]/15 text-[#d4a94c] mb-3.5">
                {d.service2500.tag}
              </span>
              <h2 class="font-display text-2xl font-bold text-white mb-1.5 leading-tight">
                {d.service2500.title}
              </h2>
              <p class="text-sm text-slate-300">{d.service2500.subtitle}</p>
            </div>
            <div class="px-8 py-7 space-y-6 flex-1 flex flex-col">
              <div class="space-y-3 text-[0.95rem] text-foreground/80 leading-relaxed">
                {d.service2500.lead.map((p) => <p>{p}</p>)}
              </div>

              <div>
                <h3 class="text-[0.8rem] font-bold uppercase tracking-[0.1em] text-[#1e3a5f] mb-3">{d.service2500.scopeTitle}</h3>
                <div class="space-y-3 text-[0.92rem] text-foreground/80 leading-relaxed">
                  {d.service2500.scopeText.map((p) => <p>{p}</p>)}
                </div>
                <p class="mt-4 border-l-[3px] border-[#d4a94c] pl-3.5 text-[0.92rem] font-semibold text-[#1e3a5f]">
                  {d.service2500.scopeNote}
                </p>
              </div>

              <div>
                <h3 class="text-[0.8rem] font-bold uppercase tracking-[0.1em] text-[#1e3a5f] mb-3">{d.service2500.getTitle}</h3>
                <ul class="space-y-2.5">
                  {
                    d.service2500.getList.map((item) => (
                      <li class="flex items-start gap-3 text-[0.92rem] text-foreground/90">
                        <span class="mt-[0.5rem] h-1.5 w-1.5 rounded-[2px] bg-[#d4a94c] shrink-0" />
                        <span>{item}</span>
                      </li>
                    ))
                  }
                </ul>
              </div>

              <div class="mt-auto pt-1">
                <h3 class="text-[0.8rem] font-bold uppercase tracking-[0.1em] text-[#1e3a5f] mb-2">{d.service2500.verifyTitle}</h3>
                <p class="text-[0.92rem] text-foreground/80 leading-relaxed">{d.service2500.verifyText}</p>
                <p class="mt-3 pt-3 border-t border-border text-xs text-muted-foreground leading-relaxed">{d.service2500.verifyPhotos}</p>
              </div>
            </div>
          </article>

          <!-- CARD 2: DMC 3500 -->
          <article class="bg-card rounded-xl border border-border overflow-hidden flex flex-col">
            <div class="bg-[#1e3a5f] p-8 pb-7">
              <span class="inline-block px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.12em] rounded bg-[#d4a94c]/15 text-[#d4a94c] mb-3.5">
                {d.service3500.tag}
              </span>
              <h2 class="font-display text-2xl font-bold text-white mb-1.5 leading-tight">
                {d.service3500.title}
              </h2>
              <p class="text-sm text-slate-300">{d.service3500.subtitle}</p>
            </div>
            <div class="px-8 py-7 space-y-6 flex-1 flex flex-col">
              <div class="space-y-3 text-[0.95rem] text-foreground/80 leading-relaxed">
                {d.service3500.lead.map((p) => <p>{p}</p>)}
              </div>

              <div>
                <h3 class="text-[0.8rem] font-bold uppercase tracking-[0.1em] text-[#1e3a5f] mb-3">{d.service3500.scopeTitle}</h3>
                <div class="space-y-3 text-[0.92rem] text-foreground/80 leading-relaxed">
                  {d.service3500.scopeText.map((p) => <p>{p}</p>)}
                </div>
                <p class="mt-4 border-l-[3px] border-[#d4a94c] pl-3.5 text-[0.92rem] font-semibold text-[#1e3a5f]">
                  {d.service3500.scopeNote}
                </p>
              </div>
            </div>
          </article>
        </div>
      </section>

      <!-- HOW IT WORKS -->
      <section id="how" class="py-16 px-6">
        <div class="container mx-auto max-w-4xl">
          <h2 class="font-display text-3xl font-bold text-foreground mb-12 text-center">
            {d.howItWorks.title}
          </h2>
          <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-8">
            <div class="text-center">
              <div class="font-display text-4xl font-bold text-[#1e3a5f] mb-2">01</div>
              <h4 class="font-semibold text-foreground mb-2">{d.howItWorks.step1}</h4>
              <p class="text-sm text-muted-foreground">{d.howItWorks.step1Desc}</p>
            </div>
            <div class="text-center">
              <div class="font-display text-4xl font-bold text-[#1e3a5f] mb-2">02</div>
              <h4 class="font-semibold text-foreground mb-2">{d.howItWorks.step2}</h4>
              <p class="text-sm text-muted-foreground">{d.howItWorks.step2Desc}</p>
            </div>
            <div class="text-center">
              <div class="font-display text-4xl font-bold text-[#1e3a5f] mb-2">03</div>
              <h4 class="font-semibold text-foreground mb-2">{d.howItWorks.step3}</h4>
              <p class="text-sm text-muted-foreground">{d.howItWorks.step3Desc}</p>
            </div>
            <div class="text-center">
              <div class="font-display text-4xl font-bold text-[#1e3a5f] mb-2">04</div>
              <h4 class="font-semibold text-foreground mb-2">{d.howItWorks.step4}</h4>
              <p class="text-sm text-muted-foreground">{d.howItWorks.step4Desc}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- NOTE -->
      <section class="py-12 px-6">
        <div class="container mx-auto max-w-3xl">
          <div class="bg-card border border-[#1e3a5f] rounded-xl p-8 flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-[#1e3a5f]/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#1e3a5f]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="16" x2="12" y2="12"></line>
                <line x1="12" y1="8" x2="12.01" y2="8"></line>
              </svg>
            </div>
            <p class="text-foreground/80 text-sm leading-relaxed">
              {d.note.description}
            </p>
          </div>
        </div>
      </section>

      <!-- CONTACT -->
      <ContactIsland lang={lang} client:visible />
    </main>

    <Footer lang={lang} />
    <ChatIsland lang={lang} client:idle />
  </div>
</BaseLayout>
