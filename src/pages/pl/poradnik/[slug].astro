---
import { getGuides } from "@/lib/content-source";
import { canonicalUrl, faqSchema, breadcrumbSchema } from "@/seo/site";
import type { Guide } from "@/content/types";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/astro/Navbar.astro";
import Footer from "@/components/astro/Footer.astro";
import Breadcrumbs from "@/components/astro/Breadcrumbs.astro";
import ChatIsland from "@/islands/ChatIsland";

export async function getStaticPaths() {
  const guides = await getGuides();
  return guides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

const lang = "pl";
const { guide } = Astro.props as { guide: Guide };
const path = `poradnik/${guide.slug}`;
const url = canonicalUrl(lang, path);

const navLinks = [
  { label: "Strona główna", href: "/pl" },
  { label: "Usługi", href: "/pl/uslugi" },
  { label: "Poradnik", href: "/pl/poradnik" },
];

const jsonLd = [
  faqSchema(guide.faq),
  breadcrumbSchema([
    { name: "Strona główna", url: canonicalUrl(lang, "") },
    { name: "Poradnik", url: canonicalUrl(lang, "poradnik") },
    { name: guide.h1, url },
  ]),
];
---

<BaseLayout
  lang={lang}
  title={guide.title}
  description={guide.description}
  path={path}
  hreflangLangs={["pl"]}
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-background">
    <Navbar lang={lang} navLinks={navLinks} langSuffix="" />
    <main class="pt-24 pb-8">
      <Breadcrumbs
        items={[{ name: "Strona główna", href: "/pl" }, { name: "Poradnik", href: "/pl/poradnik" }, { name: guide.h1 }]}
      />
      <article class="container mx-auto px-6 max-w-3xl py-8">
        <h1 class="font-display text-4xl md:text-5xl font-bold text-foreground mb-6">{guide.h1}</h1>
        <p class="text-lg text-muted-foreground mb-10 leading-relaxed">{guide.lead}</p>

        {
          guide.sections.map((sec) => (
            <section class="mb-10">
              <h2 class="font-display text-2xl font-bold text-foreground mb-4">{sec.heading}</h2>
              {sec.body?.map((p) => <p class="text-foreground/80 leading-relaxed mb-3">{p}</p>)}
              {sec.bullets && (
                <ul class="list-disc list-inside space-y-2 text-foreground/80">
                  {sec.bullets.map((b) => <li>{b}</li>)}
                </ul>
              )}
            </section>
          ))
        }

        <section class="mb-10">
          <h2 class="font-display text-2xl font-bold text-foreground mb-4">Najczęstsze pytania</h2>
          <div class="space-y-5">
            {
              guide.faq.map((f) => (
                <div>
                  <h3 class="font-semibold text-foreground mb-1">{f.q}</h3>
                  <p class="text-foreground/80 leading-relaxed">{f.a}</p>
                </div>
              ))
            }
          </div>
        </section>

        <!-- CTA to the relevant service -->
        <aside class="flex flex-col justify-between gap-4 rounded-2xl border border-terracotta/30 p-7 sm:flex-row sm:items-center" style="background-color: hsl(18 48% 92% / 0.55)">
          <p class="text-foreground/80 text-sm leading-relaxed">{guide.cta.text}</p>
          <a
            href={guide.cta.href}
            class="btn-primary whitespace-nowrap"
          >
            {guide.cta.label}
          </a>
        </aside>
      </article>
    </main>
    <Footer lang={lang} />
    <ChatIsland lang={lang} client:idle />
  </div>
</BaseLayout>
