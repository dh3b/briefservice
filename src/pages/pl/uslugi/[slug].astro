---
import { getServicePages, getGuides } from "@/lib/content-source";
import { canonicalUrl, serviceSchema, faqSchema, breadcrumbSchema } from "@/seo/site";
import type { ServicePage } from "@/content/types";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/astro/Navbar.astro";
import Footer from "@/components/astro/Footer.astro";
import Breadcrumbs from "@/components/astro/Breadcrumbs.astro";
import ContactIsland from "@/islands/ContactIsland";
import ChatIsland from "@/islands/ChatIsland";

export async function getStaticPaths() {
  const [services, guides] = await Promise.all([getServicePages(), getGuides()]);
  const guideBySlug = new Map(guides.map((g) => [g.slug, g]));
  return services.map((service) => ({
    params: { slug: service.slug },
    props: {
      service,
      related: (service.relatedGuides ?? [])
        .map((s) => guideBySlug.get(s))
        .filter((g): g is NonNullable<typeof g> => Boolean(g))
        .map((g) => ({ slug: g.slug, h1: g.h1 })),
    },
  }));
}

const lang = "pl";
const { service, related } = Astro.props as {
  service: ServicePage;
  related: { slug: string; h1: string }[];
};
const path = `uslugi/${service.slug}`;
const url = canonicalUrl(lang, path);

const navLinks = [
  { label: "Strona główna", href: "/pl" },
  { label: "Usługi", href: "/pl/uslugi" },
  { label: "Poradnik", href: "/pl/poradnik" },
];

const jsonLd = [
  serviceSchema({ name: service.name, description: service.description, url }),
  faqSchema(service.faq),
  breadcrumbSchema([
    { name: "Strona główna", url: canonicalUrl(lang, "") },
    { name: "Usługi", url: canonicalUrl(lang, "uslugi") },
    { name: service.name, url },
  ]),
];
---

<BaseLayout
  lang={lang}
  title={service.title}
  description={service.description}
  path={path}
  hreflangLangs={["pl"]}
  jsonLd={jsonLd}
>
  <div class="min-h-screen bg-background">
    <Navbar lang={lang} navLinks={navLinks} langSuffix="" />
    <main class="pt-24 pb-8">
      <Breadcrumbs
        items={[{ name: "Strona główna", href: "/pl" }, { name: "Usługi", href: "/pl/uslugi" }, { name: service.name }]}
      />
      <article class="container mx-auto px-6 max-w-3xl py-8">
        <h1 class="font-display text-4xl md:text-5xl font-bold text-foreground mb-6">{service.h1}</h1>
        <p class="text-lg text-muted-foreground mb-10 leading-relaxed">{service.lead}</p>

        {
          service.sections.map((sec) => (
            <section class="mb-10">
              <h2 class="font-display text-2xl font-bold text-foreground mb-4">{sec.heading}</h2>
              {sec.body?.map((p) => <p class="text-foreground/80 leading-relaxed mb-3">{p}</p>)}
              {sec.bullets && (
                <ul class="list-disc list-inside space-y-2 text-foreground/80">
                  {sec.bullets.map((b) => <li>{b}</li>)}
                </ul>
              )}
            </section>
          ))
        }

        <section class="mb-10 bg-card border border-border rounded-xl p-6">
          <h2 class="text-sm font-bold uppercase tracking-[0.1em] text-[#1e3a5f] mb-4">Co otrzymujesz</h2>
          <ul class="space-y-2.5">
            {
              service.highlights.map((h) => (
                <li class="flex items-start gap-3 text-foreground/90">
                  <span class="mt-[0.5rem] h-1.5 w-1.5 rounded-[2px] bg-[#d4a94c] shrink-0" />
                  <span>{h}</span>
                </li>
              ))
            }
          </ul>
        </section>

        {
          service.faq.length > 0 && (
            <section class="mb-10">
              <h2 class="font-display text-2xl font-bold text-foreground mb-4">Najczęstsze pytania</h2>
              <div class="space-y-5">
                {service.faq.map((f) => (
                  <div>
                    <h3 class="font-semibold text-foreground mb-1">{f.q}</h3>
                    <p class="text-foreground/80 leading-relaxed">{f.a}</p>
                  </div>
                ))}
              </div>
            </section>
          )
        }

        {
          related.length > 0 && (
            <section>
              <h2 class="font-display text-xl font-bold text-foreground mb-3">Powiązane poradniki</h2>
              <ul class="space-y-1.5">
                {related.map((g) => (
                  <li>
                    <a href={`/pl/poradnik/${g.slug}`} class="text-primary underline underline-offset-2 hover:text-primary/70">
                      {g.h1}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }
      </article>

      <ContactIsland lang={lang} client:visible />
    </main>
    <Footer lang={lang} />
    <ChatIsland lang={lang} client:idle />
  </div>
</BaseLayout>
